@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();

    // Получаем данные из сессии
    string? currentUserAvatar = null;
    string? currentUserFirstName = null;
    string? currentUserLastName = null;
    int? currentUserId = null;
    var currentUserRoleId = User?.FindFirst("RoleId") != null
        ? int.Parse(User.FindFirst("RoleId")!.Value)
        : 0;

    if (Context.Session.IsAvailable && Context.Session.Keys.Any())
    {
        currentUserId = Context.Session.GetInt32("UserId");
        currentUserAvatar = Context.Session.GetString("UserAvatar");
        currentUserFirstName = Context.Session.GetString("UserFirstName");
        currentUserLastName = Context.Session.GetString("UserLastName");
    }

    // Роли: 1 - Админ, 2 - Инженер/Саппорт, 3 - Пользователь
    bool showUsersTab = currentUserRoleId == 1 || currentUserRoleId == 2;
}

<aside class="sidebar">
    <div class="sidebar-menu">
        <div class="logo-item">
            <div class="menu-icon">
                <img src="/images/logo.png" alt="Logo">
            </div>
        </div>

        <!-- Все заявки -->
        <a href="/Tickets" class="menu-item @(controller == "Tickets" && action == "Index" ? "active" : "")">
            <div class="menu-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-8 2h6v2h-6V6zm0 4h6v2h-6v-2zm-6 6h12v2H6v-2zm0-4h4v2H6v-2zm0-4h4v2H6V8z" />
                </svg>
            </div>
            <span class="menu-text">Все заявки</span>
        </a>

        <!-- Мои заявки -->
        <a href="/Tickets/My" class="menu-item @(controller == "Tickets" && action == "My" ? "active" : "")">
            <div class="menu-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M12 12c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm6 3c0 1.1-.9 2-2 2H8c-1.1 0-2-.9-2-2v-2c0-1.1.9-2 2-2h8c1.1 0 2 .9 2 2v2z" />
                </svg>
            </div>
            <span class="menu-text">Мои заявки</span>
        </a>

        <!-- Назначенные мне -->
        <a href="/Tickets/Assigned" class="menu-item @(controller == "Tickets" && action == "Assigned" ? "active" : "")">
            <div class="menu-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm4 12h-4v3h-2v-3H8v-2h4V7h2v6h4v2z" />
                </svg>
            </div>
            <span class="menu-text">Назначенные мне</span>
        </a>

        <!-- Создать заявку -->
        <a asp-action="Create" asp-controller="Ticket" class="menu-item @(controller == "Tickets" && action == "Create" ? "active" : "")">
            <div class="menu-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                </svg>
            </div>
            <span class="menu-text">Создать заявку</span>
        </a>

        <div class="menu-divider"></div>

        <!-- УПРАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯМИ (для Админа и Инженера) -->
        @if (showUsersTab)
        {
            <a href="/Admin/Users" class="menu-item @(controller == "Admin" && action == "Users" ? "active" : "")">
                <div class="menu-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3">
                        <path d="M40-160v-112q0-34 17.5-62.5T104-378q62-31 126-46.5T360-440q66 0 130 15.5T616-378q29 15 46.5 43.5T680-272v112H40Zm720 0v-120q0-44-24.5-84.5T666-434q51 6 96 20.5t84 35.5q36 20 55 44.5t19 53.5v120H760ZM247-527q-47-47-47-113t47-113q47-47 113-47t113 47q47 47 47 113t-47 113q-47 47-113 47t-113-47Zm466 0q-47 47-113 47-11 0-28-2.5t-28-5.5q27-32 41.5-71t14.5-81q0-42-14.5-81T544-792q14-5 28-6.5t28-1.5q66 0 113 47t47 113q0 66-47 113ZM120-240h480v-32q0-11-5.5-20T580-306q-54-27-109-40.5T360-360q-56 0-111 13.5T140-306q-9 5-14.5 14t-5.5 20v32Zm296.5-343.5Q440-607 440-640t-23.5-56.5Q393-720 360-720t-56.5 23.5Q280-673 280-640t23.5 56.5Q327-560 360-560t56.5-23.5ZM360-240Zm0-400Z" />
                    </svg>
                </div>
                <span class="menu-text">Пользователи</span>
            </a>
        }

        <!-- СПРАВОЧНИКИ (только для админа) -->
        @if (currentUserRoleId == 1)
        {
            <a href="/Reference" class="menu-item @(controller == "Reference" ? "active" : "")">
                <div class="menu-icon">
                    <svg viewBox="0 0 24 24" width="24" height="24">
                        <path d="M4 6h16v2H4V6zm2-4h12v2H6V2zm16 8H2v12h20V10zm-2 10H4v-8h16v8z" />
                    </svg>
                </div>
                <span class="menu-text">Справочники</span>
            </a>
        }

        <!-- Архив -->
        <a href="/Tickets/Archive" class="menu-item @(controller == "Tickets" && action == "Archive" ? "active" : "")">
            <div class="menu-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z" />
                </svg>
            </div>
            <span class="menu-text">Архив</span>
        </a>

        <!-- Помощь -->
        <a href="/Help" class="menu-item @(controller == "Help" ? "active" : "")">
            <div class="menu-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                </svg>
            </div>
            <span class="menu-text">Помощь</span>
        </a>

        <div class="menu-divider"></div>

        <!-- Профиль пользователя (прижат к низу) -->
        <div style="margin-top: auto;">
            <a href="/Admin/UserDetails/@currentUserId?editMode=false" class="menu-item user-profile">
                <div class="user-avatar">
                    @if (!string.IsNullOrEmpty(currentUserAvatar))
                    {
                        <img src="@currentUserAvatar" alt="Avatar" class="sidebar-avatar" />
                    }
                    else
                    {
                        <div class="sidebar-avatar-placeholder">
                            @((currentUserFirstName?.FirstOrDefault().ToString() ?? "?") + (currentUserLastName?.FirstOrDefault().ToString() ?? ""))
                        </div>
                    }
                </div>
                <span class="menu-text user-name">@currentUserLastName @currentUserFirstName</span>
            </a>

            <!-- Выход -->
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="menu-item">
                    <div class="menu-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.59L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                        </svg>
                    </div>
                    <span class="menu-text">Выйти</span>
                </button>
            </form>
        </div>
    </div>
</aside>