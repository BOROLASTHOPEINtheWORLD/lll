@model labsupport.Models.User

<div class="form-grid">
    <!-- Аватарка -->
    <div class="form-group full-width" style="text-align: center;">
        <label class="form-label">Аватар</label>
        <div class="avatar-upload">
            <div class="avatar-preview" id="avatarPreview" onclick="document.getElementById('avatarInput').click()">
                @{
                    ViewBag.AvatarSize = "default";
                }
                <partial name="_UserAvatar" model="Model" />
            </div>
            <input type="file" id="avatarInput" name="AvatarFile" accept="image/jpeg,image/png,image/gif" style="display: none;" onchange="previewAvatar(this)" />
            <input type="hidden" name="CurrentAvatarPath" value="@(Model?.AvatarPath)" />
            <button type="button" class="btn-remove-avatar" onclick="removeAvatar()">Удалить аватар</button>
            <div><small>Нажмите на аватар для загрузки</small></div>
        </div>
    </div>

    <div class="form-group">
        <label class="form-label">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
            Фамилия <span style="color: #D32F2F;">*</span>
        </label>
        <input type="text" name="LastName" class="form-control" value="@(Model?.LastName)" required onchange="updateAvatarPlaceholder()" />
    </div>

    <div class="form-group">
        <label class="form-label">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
            Имя <span style="color: #D32F2F;">*</span>
        </label>
        <input type="text" name="FirstName" class="form-control" value="@(Model?.FirstName)" required onchange="updateAvatarPlaceholder()" />
    </div>

    <div class="form-group">
        <label class="form-label">Отчество</label>
        <input type="text" name="MiddleName" class="form-control" value="@(Model?.MiddleName)" />
    </div>

    <div class="form-group">
        <label class="form-label">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
            Логин <span style="color: #D32F2F;">*</span>
        </label>
        <input type="text" name="Username" class="form-control" value="@(Model?.Username)" required />
        <small style="font-size: 0.7rem; color: var(--text-secondary); margin-top: 4px;">Используется для входа в систему</small>
    </div>

    <div class="form-group">
        <label class="form-label">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
            </svg>
            Email <span style="color: #D32F2F;">*</span>
        </label>
        <input type="email" name="Email" class="form-control" value="@(Model?.Email)" required />
    </div>

    @if (ViewBag.IsNewUser == true)
    {
        <div class="form-group">
            <label class="form-label">
                <svg viewBox="0 0 24 24" width="16" height="16">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" />
                </svg>
                Пароль <span style="color: #D32F2F;">*</span>
            </label>
            <input type="password" name="Password" class="form-control" required />
            <small style="font-size: 0.7rem; color: var(--text-secondary); margin-top: 4px;">Минимум 6 символов</small>
        </div>

        <div class="form-group">
            <label class="form-label">
                <svg viewBox="0 0 24 24" width="16" height="16">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" />
                </svg>
                Подтверждение пароля <span style="color: #D32F2F;">*</span>
            </label>
            <input type="password" name="ConfirmPassword" class="form-control" required />
        </div>
    }

    <!-- Телефон -->
    <div class="form-group">
        <label class="form-label">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" />
            </svg>
            Телефон
        </label>
        <input type="tel" name="Phone" class="form-control" value="@(Model?.Phone)" />
    </div>

    <!-- ===== СМЕНА ПАРОЛЯ (ТОЛЬКО ДЛЯ РЕДАКТИРОВАНИЯ) ===== -->
    @if (ViewBag.IsNewUser != true)
    {
        <div class="form-group">
            <label class="form-label">
                <svg viewBox="0 0 24 24" width="16" height="16">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" />
                </svg>
                Новый пароль
            </label>
            <input type="password" name="NewPassword" class="form-control" />
            <small style="font-size: 0.7rem; color: var(--text-secondary); margin-top: 4px;">Оставьте пустым, если не хотите менять пароль</small>
        </div>

        <div class="form-group">
            <label class="form-label">
                <svg viewBox="0 0 24 24" width="16" height="16">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" />
                </svg>
                Подтверждение нового пароля
            </label>
            <input type="password" name="ConfirmNewPassword" class="form-control" />
        </div>
    }

    <!-- Роль -->
    <div class="form-group">
        <label class="form-label">
            <svg viewBox="0 0 24 24" width="16" height="16">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 4c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm0 13c-1.67 0-3.14-.85-4-2.15.02-1.32 2.67-2.05 4-2.05s3.98.73 4 2.05c-.86 1.3-2.33 2.15-4 2.15z" />
            </svg>
            Роль <span style="color: #D32F2F;">*</span>
        </label>
        <select name="RoleId" class="form-control" required>
            <option value="">Выберите роль</option>
            @foreach (var role in ViewBag.Roles as List<labsupport.Models.Role>)
            {
                <option value="@role.Id" selected="@(Model?.RoleId == role.Id)">
                    @role.Name
                </option>
            }
        </select>
    </div>

    <div class="form-group">
        <label class="form-label">Отдел</label>
        <select name="DepartmentId" class="form-control">
            <option value="">Не указан</option>
            @foreach (var dept in ViewBag.Departments as List<labsupport.Models.Department>)
            {
                <option value="@dept.Id" selected="@(Model?.DepartmentId == dept.Id)">
                    @dept.Name
                </option>
            }
        </select>
    </div>

    <div class="form-group">
        <label class="form-label">Должность</label>
        <select name="PositionId" class="form-control">
            <option value="">Не указана</option>
            @foreach (var pos in ViewBag.Positions as List<labsupport.Models.Position>)
            {
                <option value="@pos.Id" selected="@(Model?.PositionId == pos.Id)">
                    @pos.Name
                </option>
            }
        </select>
    </div>

    <div class="form-group">
        <label class="form-label">Статус</label>
        <div class="checkbox-group" style="display: flex; align-items: center; gap: 8px; margin-top: 8px;">
            <input type="checkbox" name="IsActive" id="IsActive" value="true" @(Model?.IsActive != false ? "checked" : "") style="width: 16px; height: 16px; accent-color: #D32F2F; cursor: pointer; margin: 0;" />
            <label for="IsActive">Активен</label>
        </div>

    </div>
</div>

<script>
    function previewAvatar(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var preview = document.getElementById('avatarPreview');
                preview.innerHTML = '<img src="' + e.target.result + '" alt="Avatar" id="avatarImg" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover;" />';
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    function updateAvatarPlaceholder() {
        var firstName = document.querySelector('input[name="FirstName"]')?.value || '';
        var lastName = document.querySelector('input[name="LastName"]')?.value || '';
        var placeholder = document.getElementById('avatarPlaceholder');
        var avatarImg = document.getElementById('avatarImg');

        if (placeholder && !avatarImg) {
            var initials = (firstName.charAt(0) || '?') + (lastName.charAt(0) || '');
            placeholder.textContent = initials;
        }
    }

    function removeAvatar() {
        document.getElementById('avatarInput').value = '';
        var preview = document.getElementById('avatarPreview');
        var firstName = document.querySelector('input[name="FirstName"]')?.value || '';
        var lastName = document.querySelector('input[name="LastName"]')?.value || '';
        var initials = (firstName.charAt(0) || '?') + (lastName.charAt(0) || '');
        preview.innerHTML = '<div class="avatar-placeholder" id="avatarPlaceholder">' + initials + '</div>';
        document.querySelector('input[name="CurrentAvatarPath"]').value = '';
    }
</script>
