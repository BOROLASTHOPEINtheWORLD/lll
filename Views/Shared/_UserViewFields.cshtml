@model labsupport.Models.User

<div class="user-details-grid">
    <!-- Аватар -->
    <div class="form-card full-width" style="text-align: center;">
        <div class="avatar-view">
            @{
                ViewBag.AvatarSize = "default";
            }
            <partial name="_UserAvatar" model="Model" />
        </div>
    </div>

    <!-- Основная информация -->
    <div class="form-card">
        <div class="form-header">
            <div class="form-header-icon">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                </svg>
            </div>
            <div class="form-header-content">
                <h2>Основная информация</h2>
                <span>Личные данные пользователя</span>
            </div>
        </div>
        <div class="info-section">
            <div class="info-row">
                <label class="info-label">ФИО</label>
                <div class="info-value highlight">@Model?.LastName @Model?.FirstName @Model?.MiddleName</div>
            </div>
            <div class="info-row">
                <label class="info-label">Логин</label>
                <div class="info-value">@Model?.Username</div>
            </div>
            <div class="info-row">
                <label class="info-label">Email</label>
                <div class="info-value">@Model?.Email</div>
            </div>
            <div class="info-row">
                <label class="info-label">Телефон</label>
                <div class="info-value">@(Model?.Phone ?? "Не указан")</div>
            </div>
            <div class="info-row">
                <label class="info-label">Статус</label>
                <div>
                    <span class="status-badge @(Model?.IsActive == true ? "status-open" : "status-default")">
                        @(Model?.IsActive == true ? "Активен" : "Заблокирован")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Рабочая информация -->
    <div class="form-card">
        <div class="form-header">
            <div class="form-header-icon">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z" />
                </svg>
            </div>
            <div class="form-header-content">
                <h2>Рабочая информация</h2>
                <span>Должность и отдел</span>
            </div>
        </div>
        <div class="info-section">
            <div class="info-row">
                <label class="info-label">Роль</label>
                <div class="info-value highlight">@(Model?.Role?.Name ?? "Не указана")</div>
            </div>
            <div class="info-row">
                <label class="info-label">Отдел</label>
                <div class="info-value">@(Model?.Department?.Name ?? "Не указан")</div>
            </div>
            <div class="info-row">
                <label class="info-label">Должность</label>
                <div class="info-value">@(Model?.Position?.Name ?? "Не указана")</div>
            </div>
        </div>
    </div>

    <!-- Статистика заявок -->
    <div class="form-card full-width">
        <div class="form-header">
            <div class="form-header-icon">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm0 4c2.76 0 5 2.24 5 5s-2.24 5-5 5-5-2.24-5-5 2.24-5 5-5z" />
                </svg>
            </div>
            <div class="form-header-content">
                <h2>Статистика заявок</h2>
                <span>Активность пользователя в системе</span>
            </div>
        </div>
        <div class="stats-small-grid">
            <div class="stat-card-small">
                <div class="stat-number-large red">@ViewBag.CreatedTicketsCount</div>
                <div class="stat-label">Созданных заявок</div>
            </div>
            <div class="stat-card-small">
                <div class="stat-number-large orange">@ViewBag.AssignedTicketsCount</div>
                <div class="stat-label">Назначенных заявок</div>
            </div>
            <div class="stat-card-small">
                <div class="stat-number-large green">@ViewBag.OpenTicketsCount</div>
                <div class="stat-label">Открытых заявок</div>
            </div>
        </div>
    </div>
</div>

