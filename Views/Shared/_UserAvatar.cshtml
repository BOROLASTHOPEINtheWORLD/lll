@model labsupport.Models.User

@if (!string.IsNullOrEmpty(Model?.AvatarPath))
{
    <img src="@Model.AvatarPath" alt="Avatar" class="@(ViewBag.AvatarSize == "small" ? "avatar-icon" : "avatar-default")" />
}
else
{
    <div class="@(ViewBag.AvatarSize == "small" ? "avatar-icon-placeholder" : "avatar-default-placeholder")">
        @((Model?.FirstName?.FirstOrDefault().ToString()) + (Model?.LastName?.FirstOrDefault().ToString()))
    </div>
}

