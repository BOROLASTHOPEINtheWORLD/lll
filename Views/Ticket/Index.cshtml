@model IEnumerable<labsupport.Models.Ticket>

@{
    ViewData["Title"] = "Все заявки";
}

<div class="app-container">
    @await Html.PartialAsync("_Sidebar")

    <main class="main-content">
        <div class="content-header">
            <h1>Все заявки</h1>
            <a asp-controller="Ticket" asp-action="Create" class="btn-create">
                <svg viewBox="0 0 24 24" width="18" height="18">
                    <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                </svg>
                Создать заявку
            </a>
        </div>

        <!-- Фильтры -->
        <div class="filters-section">
            <form method="get" class="filters-form">
                <div class="filter-group">
                    <label>Статус:</label>
                    <select name="statusId" class="filter-select" onchange="this.form.submit()">
                        <option value="">Все</option>
                        <option value="1" selected="@(ViewBag.SelectedStatusId == 1)">Новая</option>
                        <option value="2" selected="@(ViewBag.SelectedStatusId == 2)">В работе</option>
                        <option value="3" selected="@(ViewBag.SelectedStatusId == 3)">На проверке</option>
                        <option value="4" selected="@(ViewBag.SelectedStatusId == 4)">Завершена</option>
                        <option value="5" selected="@(ViewBag.SelectedStatusId == 5)">Отменена</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>Приоритет:</label>
                    <select name="priority" class="filter-select" onchange="this.form.submit()">
                        <option value="">Все</option>
                        <option value="5" selected="@(ViewBag.SelectedPriority == 5)">★★★★★</option>
                        <option value="4" selected="@(ViewBag.SelectedPriority == 4)">★★★★☆</option>
                        <option value="3" selected="@(ViewBag.SelectedPriority == 3)">★★★☆☆</option>
                        <option value="2" selected="@(ViewBag.SelectedPriority == 2)">★★☆☆☆</option>
                        <option value="1" selected="@(ViewBag.SelectedPriority == 1)">★☆☆☆☆</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>Поиск:</label>
                    <input type="text" name="search" class="search-input" placeholder="Номер или название..." value="@ViewBag.SearchTerm" onchange="this.form.submit()">
                </div>

                <a href="@Url.Action("Index")" class="btn-reset">Сбросить</a>
            </form>
        </div>

        <!-- Таблица с прокруткой -->
        <div style="overflow-x: auto; border-radius: 8px; box-shadow: var(--shadow-sm);">
            <table style="width: 100%; border-collapse: collapse; background: white; min-width: 1100px;">
                <thead>
                    <tr style="background: #FAFAFA; border-bottom: 1px solid var(--border-color);">
                        <th style="padding: 14px 16px; text-align: left;">№</th>
                        <th style="padding: 14px 16px; text-align: left;">Название</th>
                        <th style="padding: 14px 16px; text-align: left;">Статус</th>
                        <th style="padding: 14px 16px; text-align: left;">Категория</th>
                        <th style="padding: 14px 16px; text-align: left;">Приоритет</th>
                        <th style="padding: 14px 16px; text-align: left;">Исполнитель</th>
                        <th style="padding: 14px 16px; text-align: left;">Создана</th>
                        <th style="padding: 14px 16px; text-align: left;">Обновлена</th>
                        <th style="padding: 14px 16px; text-align: left;">Срок</th>
                        <th style="padding: 14px 16px; text-align: left;">SLA</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var ticket in Model)
                        {
                            string statusClass = ticket.Status?.Name switch
                            {
                                "Новая" => "status-open",
                                "В работе" => "status-progress",
                                "На проверке" => "status-progress",
                                "Завершена" => "status-resolved",
                                "Отменена" => "status-default",
                                _ => "status-default"
                            };

                            bool isOverdue = ticket.DueDate.HasValue && ticket.DueDate < DateTime.Now;
                            string slaText = "Без срока";
                            string slaColor = "#6c757d";

                            if (ticket.DueDate.HasValue)
                            {
                                var daysLeft = (ticket.DueDate.Value - DateTime.Now).TotalDays;
                                if (daysLeft < 0) { slaText = "Просрочена"; slaColor = "#ef4444"; }
                                else if (daysLeft < 1) { slaText = "На грани"; slaColor = "#f59e0b"; }
                                else if (daysLeft < 3) { slaText = "Скоро"; slaColor = "#f59e0b"; }
                                else { slaText = "В норме"; slaColor = "#10b981"; }
                            }

                            <tr style="border-bottom: 1px solid var(--border-color);">
                                <td style="padding: 12px 16px;">
                                    <a href="@Url.Action("Details", "Ticket", new { id = ticket.Id })" style="color: var(--primary-red); text-decoration: none;">
                                        @ticket.TicketNumber
                                    </a>
                                </td>
                                <td style="padding: 12px 16px;">@ticket.Title</td>
                                <td style="padding: 12px 16px;">
                                    <span class="status-badge @statusClass">@(ticket.Status?.Name ?? "-")</span>
                                </td>
                                <td style="padding: 12px 16px;">@(ticket.Category?.Name ?? "-")</td>
                                <td style="padding: 12px 16px;">
                                    <div style="display: flex; gap: 2px;">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= (ticket.Priority))
                                            {
                                                <span style="color: #F59E0B;">★</span>
                                            }
                                            else
                                            {
                                                <span style="color: #D1D5DB;">☆</span>
                                            }
                                        }
                                    </div>
                                </td>
                                <td style="padding: 12px 16px;">@(ticket.AssignedTo?.FirstName ?? "-")</td>
                                <td style="padding: 12px 16px;">@(ticket.CreatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                <td style="padding: 12px 16px;">@(ticket.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                <td style="padding: 12px 16px;">
                                    @if (ticket.DueDate.HasValue)
                                    {
                                        <span style="@(isOverdue ? "color: #ef4444; font-weight: 600;" : "")">
                                            @ticket.DueDate.Value.ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color: #ccc;">—</span>
                                    }
                                </td>
                                <td style="padding: 12px 16px;">
                                    @if (ticket.DueDate.HasValue)
                                    {
                                        <span style="display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; color: white; background: @slaColor;">
                                            @slaText
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color: #ccc;">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" style="text-align: center; padding: 40px;">
                                <p>Нет заявок для отображения</p>
                                <a asp-controller="Ticket" asp-action="Create">Создать первую заявку</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Пагинация -->
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div style="display: flex; justify-content: center; gap: 8px; margin-top: 24px;">
                @if (ViewBag.CurrentPage > 1)
                {
                    <button class="page-btn" onclick="goToPage(@(ViewBag.CurrentPage - 1))">← Назад</button>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.CurrentPage)
                    {
                        <button class="page-btn active" style="background: var(--primary-red); color: white;">@i</button>
                    }
                    else if (Math.Abs(i - ViewBag.CurrentPage) <= 2 || i == 1 || i == ViewBag.TotalPages)
                    {
                        <button class="page-btn" onclick="goToPage(@i)">@i</button>
                    }
                    else if (Math.Abs(i - ViewBag.CurrentPage) == 3)
                    {
                        <span style="padding: 8px 4px;">...</span>
                    }
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <button class="page-btn" onclick="goToPage(@(ViewBag.CurrentPage + 1))">Вперед →</button>
                }
            </div>
        }
    </main>
</div>

<script>
    function goToPage(page) {
        var url = new URL(window.location.href);
        url.searchParams.set('page', page);
        window.location.href = url.toString();
    }
</script>

<style>
    .page-btn {
        padding: 8px 14px;
        border: 1px solid var(--border-color);
        background: white;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .page-btn:hover {
            border-color: var(--primary-red);
            color: var(--primary-red);
        }
</style>