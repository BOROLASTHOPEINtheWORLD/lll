                        {
@if (comment.UserId == null)
{
    <div class="message message-system" data-comment-id="@comment.Id">
        <div class="system-message-content">
            <svg class="system-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h2v2h-2v-2zm0-10h2v8h-2V7z"/></svg><span class="system-message-text">@Html.Raw(comment.Content.Replace("\n", "<br>"))</span><span class="message-time local-time system-time" data-time="@comment.CreatedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">@comment.CreatedAt?.ToString("HH:mm")</span>
        </div>
    </div>
}

                            else
                            {
