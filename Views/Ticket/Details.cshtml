                        <div class="info-value">${onlineStatus}</div>
                    </div>
                    <div class="form-group" style="margin-top: 20px;">
                        <label for="delegation-reason">Причина делегирования:</label>
                        <textarea id="delegation-reason" rows="3" class="form-textarea" placeholder="Укажите причину делегирования заявки..." required></textarea>
                    </div>
