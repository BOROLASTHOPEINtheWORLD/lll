                            filePath: "@(attachment.FilePath.Replace("\\", "\\\\").Replace("\"", "\\\"").Replace("'", "\\'"))",
                            isImage: @isImage.ToString().ToLower()
                        };
                        var preview = window.FilePreviewHelper.createVirtualFilePreview(fileData, null, true);
                        document.getElementById('ticket-attachments-container').appendChild(preview);
                    })();
                    </text>
                }
            }
        }
    
        // Контекстное меню для сообщений
        let currentCommentId = null, currentCommentContent = '';
        const ctxMenu = document.getElementById('context-menu');
        const ctxEditBtn = document.getElementById('ctx-edit-btn');
        const ctxDeleteBtn = document.getElementById('ctx-delete-btn');
    
        document.querySelectorAll('.message-options-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const messageEl = this.closest('.message');
                if (!messageEl) return;
                const commentId = parseInt(messageEl.dataset.commentId);
                if (isNaN(commentId)) return;
                e.preventDefault();
                const contentEl = messageEl.querySelector('.message-text');
                currentCommentId = commentId;
                currentCommentContent = contentEl?.textContent || '';
    
                ctxMenu.style.display = 'block';
                ctxMenu.style.left = (e.clientX - 180) + 'px';
                ctxMenu.style.top = e.clientY + 'px';
    
                ctxEditBtn.onclick = function () {
                    ChatHelper.editMessage(currentCommentId, currentCommentContent);
                    ctxMenu.style.display = 'none';
                };
                ctxDeleteBtn.onclick = function () {
                    ChatHelper.deleteMessageRequest(currentCommentId);
                    ctxMenu.style.display = 'none';
                };
                document.addEventListener('click', function hideMenu() {
                    ctxMenu.style.display = 'none';
                    document.removeEventListener('click', hideMenu);
                }, { once: true });
            });
        });
    
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && ctxMenu.style.display === 'block') {
                ctxMenu.style.display = 'none';
            }
        });
    
        const textarea = document.getElementById('comment-content');
        if (textarea) {
            textarea.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = (this.scrollHeight) + 'px';
            });
        }
    });
    
    function GetFileSize(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }

</script>