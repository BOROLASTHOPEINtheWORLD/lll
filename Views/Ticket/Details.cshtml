    window.toggleHistory = function() {
        const container = document.getElementById('history-list-container');
        const icon = document.getElementById('history-toggle-icon');
        
        if (container.style.maxHeight && container.style.maxHeight !== 'none') {
            container.style.maxHeight = 'none';
            icon.style.transform = 'rotate(0deg)';
        } else {
            container.style.maxHeight = (container.scrollHeight + 50) + 'px';
            icon.style.transform = 'rotate(180deg)';
            setTimeout(() => {
                container.style.maxHeight = 'none';
            }, 300);
        }
    }

    window.toggleHiddenHistory = function() {
        const hiddenItems = document.getElementById('hidden-history-items');
        const btnText = document.getElementById('toggle-history-text');
        const btnIcon = document.getElementById('toggle-history-icon');
    
        let hiddenCount = 0;
        const historySection = document.getElementById('history-section');
        if (historySection && historySection.dataset.hiddenCount) {
            hiddenCount = parseInt(historySection.dataset.hiddenCount);
        } else if (btnText && btnText.textContent) {
            const match = btnText.textContent.match(/\d+/);
            if (match) hiddenCount = parseInt(match[0]);
        }
    
        if (hiddenItems.style.display === 'none' || !hiddenItems.style.display) {
            hiddenItems.style.display = 'block';
            btnText.textContent = 'Скрыть';
            if (btnIcon) btnIcon.style.transform = 'rotate(180deg)';
        } else {
            hiddenItems.style.display = 'none';
            btnText.textContent = 'Показать еще ' + hiddenCount;
            if (btnIcon) btnIcon.style.transform = 'rotate(0deg)';
        }
    }

