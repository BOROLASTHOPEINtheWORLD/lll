       window.confirmDelegation = async function() {
        if (!selectedUserId) {
            showNotification('Выберите пользователя', 'error');
            return;
        }
        const reasonTextarea = document.getElementById('delegation-reason');
        const reason = reasonTextarea ? reasonTextarea.value : '';
        if (!reason.trim()) {
            showNotification('Укажите причину делегирования', 'error');
            return;
        }

        try {
            const response = await fetch('/Ticket/DelegateTicket', {
                method: 'POST',
                credentials: 'same-origin',   // обязательно для передачи кук
                headers: {
                    'Content-Type': 'application/json'
                    // токен не нужен, пока стоит [IgnoreAntiforgeryToken]
                },
                body: JSON.stringify({
                    ticketId: '@Model.Ticket.Id',   // строка, чтобы не потерять точность
                    toUserId: selectedUserId,
                    reason: reason
                })
            });

            if (response.ok) {
                showNotification('Заявка успешно делегирована', 'success');
                closeDelegationModal();
                setTimeout(() => window.location.reload(), 1000);
            } else {
                const errorText = await response.text();
                console.error('Ошибка делегирования:', errorText);
                showNotification(`Ошибка: ${errorText}`, 'error');
            }
        } catch (err) {
            console.error(err);
            showNotification(`Ошибка сети: ${err.message}`, 'error');
        }
    };
    
