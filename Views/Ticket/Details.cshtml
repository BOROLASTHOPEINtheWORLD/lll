@model labsupport.ViewModels.TicketDetailsViewModel

@{
    ViewData["Title"] = $"Заявка #{Model.Ticket.TicketNumber}";
    var currentUserRoleId = User?.FindFirst("RoleId") != null ? int.Parse(User.FindFirst("RoleId")!.Value) : 0;
    bool isEngineerOrAdmin = currentUserRoleId == 1 || currentUserRoleId == 2;
}

<div class="app-container">
    @await Html.PartialAsync("_Sidebar")

    <main class="main-content ticket-details-page">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">@TempData["Error"]</div>
        }

        <div class="ticket-details-layout">
            <!-- Левая часть - Информация о заявке -->
            <div class="ticket-info-panel">
                <!-- Заголовок и мета -->
                <div class="ticket-header">
                    <div class="ticket-header-top">
                        <div>
                            <h1 class="ticket-title">@Model.Ticket.Title</h1>
                            <p class="ticket-number">Заявка #@Model.Ticket.TicketNumber</p>
                        </div>
                        <a href="@Url.Action("Index", "Ticket")" class="back-link">← К списку</a>
                    </div>

                    <div class="ticket-meta">
                        <div class="status-badge @(Model.Ticket.Status.Name switch {
                            "Новая" => "status-new",
                            "В работе" => "status-progress",
                            "На проверке" => "status-review",
                            "Завершена" => "status-done",
                            "Отменена" => "status-cancel"
                        })">
                            <span class="status-icon">Статус заявки: </span>
                            @Model.Ticket.Status.Name
                        </div>
                        
                        <div class="priority-meta">
                            <span class="status-icon">Приоритет: </span>
                            <div class="priority-stars">
                                <div class="stars-container">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="star @(i <= Model.Ticket.Priority ? "active" : "")">★</span>
                                    }
                                </div>
                                <span class="priority-label-text" data-priority="@Model.Ticket.Priority">
                                    @(Model.Ticket.Priority switch {
                                        1 => "Низкий",
                                        2 => "Ниже среднего",
                                        3 => "Средний",
                                        4 => "Выше среднего",
                                        5 => "Высокий",
                                        _ => "Не задан"
                                    })
                                </span>
                            </div>
                        </div>

                        @if (Model.Ticket.DueDate.HasValue)
                        {
                            <div class="due-date @(Model.Ticket.DueDate < DateTime.Now ? "overdue" : "")">
                                <svg class="meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <path d="M16 2v4"></path>
                                    <path d="M8 2v4"></path>
                                    <path d="M3 10h18"></path>
                                </svg>
                                @Model.Ticket.DueDate?.ToString("dd.MM.yyyy HH:mm")
                            </div>
                        }
                    </div>
                </div>

                <!-- Основная информация -->
                <div class="ticket-section">
                    <h2 class="section-title">
                        Основная информация
                    </h2>
                    
                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">
                               <svg stroke="currentColor" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#333333"><path d="m260-520 220-360 220 360H260ZM700-80q-75 0-127.5-52.5T520-260q0-75 52.5-127.5T700-440q75 0 127.5 52.5T880-260q0 75-52.5 127.5T700-80Zm-580-20v-320h320v320H120Zm580-60q42 0 71-29t29-71q0-42-29-71t-71-29q-42 0-71 29t-29 71q0 42 29 71t71 29Zm-500-20h160v-160H200v160Zm202-420h156l-78-126-78 126Zm78 0ZM360-340Zm340 80Z"/></svg>
                                Категория
                            </span>
                            <span class="info-value">@Model.Ticket.Category?.Name</span>
                        </div>
                        
                        <div class="info-item">
                            <span class="info-label">
                                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#333333"><path d="M200-80q-33 0-56.5-23.5T120-160v-560q0-33 23.5-56.5T200-800h40v-80h80v80h320v-80h80v80h40q33 0 56.5 23.5T840-720v560q0 33-23.5 56.5T760-80H200Zm0-80h560v-400H200v400Zm0-480h560v-80H200v80Zm0 0v-80 80Z"/></svg>
                                Создана
                            </span>
                            <span class="info-value local-time" data-time="@Model.Ticket.CreatedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">
                                @Model.Ticket.CreatedAt?.ToString("dd.MM.yy HH:mm")
                            </span>
                        </div>
                        
                        <div class="info-item">
                            <span class="info-label">
                              <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#333333"><path d="M200-80q-33 0-56.5-23.5T120-160v-560q0-33 23.5-56.5T200-800h40v-80h80v80h320v-80h80v80h40q33 0 56.5 23.5T840-720v200h-80v-40H200v400h280v80H200Zm0-560h560v-80H200v80Zm0 0v-80 80ZM560-80v-123l221-220q9-9 20-13t22-4q12 0 23 4.5t20 13.5l37 37q8 9 12.5 20t4.5 22q0 11-4 22.5T903-300L683-80H560Zm300-263-37-37 37 37ZM620-140h38l121-122-18-19-19-18-122 121v38Zm141-141-19-18 37 37-18-19Z"/></svg>
                                Обновлена
                            </span>
                            <span class="info-value local-time" data-time="@Model.Ticket.UpdatedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">
                                @Model.Ticket.UpdatedAt?.ToString("dd.MM.yy HH:mm")
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Описание -->
                <div class="ticket-section">
                    <h2 class="section-title">
                        Описание
                    </h2>
                    <div class="ticket-description">@(Model.Ticket.Description ?? "Описание отсутствует")</div>
                </div>

               <!-- Вложения -->
<!-- Вложения -->
@if (Model.Ticket.TicketAttachments.Any())
{
    <div class="ticket-section">
        <h2 class="section-title">
            <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
            </svg>
            Вложения (@Model.Ticket.TicketAttachments.Count)
        </h2>
        <div id="ticket-attachments-container" class="ticket-attachments-grid"></div>
    </div>
}

                <!-- Участники -->
                <div class="ticket-section">
                    <h2 class="section-title">
                        Участники
                    </h2>
                    <div class="participants-grid">
                        <div class="participant-card">
                            <div class="participant-header">
                                <svg class="participant-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                </svg>
                                Автор
                            </div>
                            <div class="participant-content">
                                <div class="participant-avatar">
                                    <partial name="_UserAvatar" model="Model.Ticket.CreatedBy" />
                                </div>
                                <div class="participant-info">
                                    <span class="participant-name">@Model.Ticket.CreatedBy.LastName @Model.Ticket.CreatedBy.FirstName</span>
                                    <span class="participant-details">@Model.Ticket.CreatedBy.Department?.Name</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="participant-card">
                            <div class="participant-header">
                                <svg class="participant-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="8.5" cy="7" r="4"></circle>
                                    <polyline points="17 11 19 13 23 9"></polyline>
                                </svg>
                                Исполнитель
                            </div>
                            <div class="participant-content">
                                <div class="participant-avatar">
                                    <partial name="_UserAvatar" model="Model.Ticket.AssignedTo" />
                                </div>
                                <div class="participant-info">
                                    <span class="participant-name">@Model.Ticket.AssignedTo.LastName @Model.Ticket.AssignedTo.FirstName</span>
                                    <span class="participant-details">@Model.Ticket.AssignedTo.Department?.Name</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Управление (только для инженеров/админов) -->
                @if (isEngineerOrAdmin)
                {
                    <div class="ticket-section">
                        <h2 class="section-title">
                            Управление заявкой
                        </h2>
                        <div class="management-actions">
                            <div class="action-group">
                                <label class="action-label">
                                    <svg class="info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                                    </svg>
                                    Статус
                                </label>
                                <form asp-action="UpdateStatus" method="post">
                                    <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                                    <select name="statusId" class="status-select">
                                        <option value="1" selected="@(Model.Ticket.StatusId == 1)">Новая</option>
                                        <option value="2" selected="@(Model.Ticket.StatusId == 2)">В работе</option>
                                        <option value="3" selected="@(Model.Ticket.StatusId == 3)">На проверке</option>
                                        <option value="4" selected="@(Model.Ticket.StatusId == 4)">Завершена</option>
                                        <option value="5" selected="@(Model.Ticket.StatusId == 5)">Отменена</option>
                                    </select>
                                </form>
                            </div>
                            
                            <div class="action-group">
                                <label class="action-label">
                                    <svg class="info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="8.5" cy="7" r="4"></circle>
                                        <polyline points="17 11 19 13 23 9"></polyline>
                                    </svg>
                                    Исполнитель
                                </label>
                                <form asp-action="UpdateAssignment" method="post">
                                    <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                                    <select name="assignedToId" class="assignee-select">
                                        @foreach (var assignee in Model.AvailableAssignees)
                                        {
                                            <option value="@assignee.Id" selected="@(assignee.Id == Model.Ticket.AssignedToId)">
                                                @assignee.LastName @assignee.FirstName
                                            </option>
                                        }
                                    </select>
                                </form>
                            </div>
                        </div>
                    </div>
                }

                <!-- История изменений - В САМОМ НИЗУ -->
               <!-- История изменений - В САМОМ НИЗУ -->
@if (Model.History.Any())
{
    var historyList = Model.History.OrderByDescending(h => h.ChangedAt).ToList();
    var visibleCount = Math.Min(5, historyList.Count);
    var hiddenCount = historyList.Count - visibleCount;
    
    <div class="ticket-section" id="history-section" data-hidden-count="@hiddenCount">
        <div class="section-header-with-toggle" onclick="toggleHistory()">
            <h2 class="section-title">
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#333333">
                    <path d="M200-80q-33 0-56.5-23.5T120-160v-560q0-33 23.5-56.5T200-800h40v-80h80v80h320v-80h80v80h40q33 0 56.5 23.5T840-720v200h-80v-40H200v400h280v80H200Zm0-560h560v-80H200v80Zm0 0v-80 80ZM560-80v-123l221-220q9-9 20-13t22-4q12 0 23 4.5t20 13.5l37 37q8 9 12.5 20t4.5 22q0 11-4 22.5T903-300L683-80H560Zm300-263-37-37 37 37ZM620-140h38l121-122-18-19-19-18-122 121v38Zm141-141-19-18 37 37-18-19Z"/>
                </svg>
                История изменений
                <span class="history-count">(@historyList.Count)</span>
            </h2>
            <svg id="history-toggle-icon" class="toggle-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" width="24px" fill="#666">
                <path d="M440-800v487L216-537l-56 57 320 320 320-320-56-57-224 224v-487h-80Z"/>
            </svg>
        </div>
        
        <div id="history-list-container">
            <div class="history-list">
                @for (int i = 0; i < visibleCount; i++)
                {
                    var item = historyList[i];
                    <div class="history-item">
                        <div class="history-avatar">
                            @{
                                ViewBag.AvatarSize = "small";
                            }
                            <partial name="_UserAvatar" model="item.User" />
                        </div>
                        <div class="history-content">
                            <div class="history-meta">
                                <span class="history-author">@item.User.LastName @item.User.FirstName</span>
                                <span class="history-time local-time" data-time="@item.ChangedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">
                                    @item.ChangedAt?.ToString("dd.MM.yy HH:mm")
                                </span>
                            </div>
                            <div class="history-change">
                                @{
                                    var icon = "";
                                    var changeText = "";
                                    
                                    switch (item.FieldName)
                                    {
                                        case "Status":
                                            icon = "<svg class='history-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/></svg>";
                                            changeText = $"изменил(а) статус на <strong>{item.NewValue}</strong>";
                                            break;
                                        case "Priority":
                                            icon = "<svg class='history-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='10'/><path d='M12 6v6l4 2'/></svg>";
                                            changeText = $"изменил(а) приоритет на <strong>{item.NewValue}</strong>";
                                            break;
                                        case "AssignedTo":
                                            icon = "<svg class='history-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='8.5' cy='7' r='4'/><polyline points='17 11 19 13 23 9'/></svg>";
                                            changeText = $"изменил(а) исполнителя на <strong>{item.NewValue}</strong>";
                                            break;
                                        default:
                                            icon = "<svg class='history-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 20h9'/><path d='M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z'/></svg>";
                                            changeText = $"изменил(а) <strong>{item.FieldName}</strong> на «<strong>{item.NewValue}</strong>»";
                                            break;
                                    }
                                }
                                @Html.Raw(icon + changeText)
                                @if (!string.IsNullOrEmpty(item.OldValue))
                                {
                                    <span class="history-old-value">(было: @item.OldValue)</span>
                                }
                            </div>
                        </div>
                    </div>
                }
                
                @if (hiddenCount > 0)
                {
                    <div id="hidden-history-items" style="display: none;">
                        @for (int i = visibleCount; i < historyList.Count; i++)
                        {
                            var item = historyList[i];
                            <div class="history-item">
                                <div class="history-avatar">
                                    @{
                                        ViewBag.AvatarSize = "small";
                                    }
                                    <partial name="_UserAvatar" model="item.User" />
                                </div>
                                <div class="history-content">
                                    <div class="history-meta">
                                        <span class="history-author">@item.User.LastName @item.User.FirstName</span>
                                        <span class="history-time local-time" data-time="@item.ChangedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">
                                            @item.ChangedAt?.ToString("dd.MM.yy HH:mm")
                                        </span>
                                    </div>
                                    <div class="history-change">
                                        @{
                                            var iconHidden = "";
                                            var changeTextHidden = "";
                                            
                                            switch (item.FieldName)
                                            {
                                                case "Status":
                                                    iconHidden = "<svg class='history-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/></svg>";
                                                    changeTextHidden = $"изменил(а) статус на <strong>{item.NewValue}</strong>";
                                                    break;
                                                case "Priority":
                                                    iconHidden = "<svg class='history-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='10'/><path d='M12 6v6l4 2'/></svg>";
                                                    changeTextHidden = $"изменил(а) приоритет на <strong>{item.NewValue}</strong>";
                                                    break;
                                                case "AssignedTo":
                                                    iconHidden = "<svg class='history-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='8.5' cy='7' r='4'/><polyline points='17 11 19 13 23 9'/></svg>";
                                                    changeTextHidden = $"изменил(а) исполнителя на <strong>{item.NewValue}</strong>";
                                                    break;
                                                default:
                                                    iconHidden = "<svg class='history-icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 20h9'/><path d='M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z'/></svg>";
                                                    changeTextHidden = $"изменил(а) <strong>{item.FieldName}</strong> на «<strong>{item.NewValue}</strong>»";
                                                    break;
                                            }
                                        }
                                        @Html.Raw(iconHidden + changeTextHidden)
                                        @if (!string.IsNullOrEmpty(item.OldValue))
                                        {
                                            <span class="history-old-value">(было: @item.OldValue)</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="history-toggle-more">
                        <button type="button" class="toggle-history-btn" onclick="toggleHiddenHistory()">
                            <span id="toggle-history-text">Показать еще @hiddenCount</span>
                            <svg id="toggle-history-icon" xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="#666">
                                <path d="M440-800v487L216-537l-56 57 320 320 320-320-56-57-224 224v-487h-80Z"/>
                            </svg>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}
            </div>

            <!-- Правая часть - Чат -->
            <div class="chat-panel">
                <!-- ... весь код чата остается без изменений ... -->
                <div class="chat-header">
                    <div class="chat-header-top">
                        <h3>Чат заявки</h3>
                    </div>
                </div>

                <div class="chat-messages" id="chat-messages">
                    @if (!Model.Comments.Any())
                    {
                        <div class="no-messages">
                            <div class="no-messages-icon">
                                <svg viewBox="0 0 24 24">
                                    <path fill="currentColor" d="M20,2H4C2.9,2 2,2.9 2,4V22L6,18H20C21.1,18 22,17.1 22,16V4C22,2.9 21.1,2 20,2Z" />
                                </svg>
                            </div>
                            <h4>Начните обсуждение</h4>
                            <p>Напишите первый комментарий, чтобы начать обсуждение заявки</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments)
                        {
                            bool isOwnComment = comment.UserId == Model.CurrentUser.Id;
                            bool isInternal = comment.IsInternal ?? false;

                            <div class="message @(isOwnComment ? "message-own" : "") @(isInternal ? "message-internal" : "")" data-comment-id="@comment.Id">
                                <div class="message-avatar">
                                    @{
                                        ViewBag.AvatarSize = "small";
                                    }
                                    <partial name="_UserAvatar" model="comment.User"/>
                                </div>
                                <div class="message-content">
                                    <div class="message-header">
                                        <div class="message-author-info">
                                            <span class="message-author">@comment.User.LastName @comment.User.FirstName</span>
                                            @if (isInternal)
                                            {
                                                <span class="badge-internal">Внутренний</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="message-text">@comment.Content</div>

                                    @if (comment.MessageAttachments.Any())
                                    {
                                        <div class="message-attachments">
                                            @foreach (var attachment in comment.MessageAttachments)
                                            {
                                                var fileName = attachment.FileName;
                                                var extIndex = fileName.LastIndexOf('.');
                                                var extension = extIndex > 0 ? fileName.Substring(extIndex + 1).ToUpper() : "BIN";

                                                var isImage = fileName.ToLower().EndsWith(".jpg") || 
                                                                fileName.ToLower().EndsWith(".jpeg") || 
                                                                fileName.ToLower().EndsWith(".png") || 
                                                                fileName.ToLower().EndsWith(".gif") || 
                                                                fileName.ToLower().EndsWith(".webp");

                                                <div class="AttachmentCell AttachmentCell--clickable"
                                                        onclick="window.open('@Url.Content(attachment.FilePath)', '_blank')">
                                                    <div class="AttachmentCell__imageBlockContainer">
                                                        <div class="AttachmentCell__imageBlockBackground"></div>
                                                        <div class="AttachmentCell__imageBlock">
                                                            @if (isImage)
                                                            {
                                                                <div style="width:100%;height:100%;background:#f5f7fa;display:flex;align-items:center;justify-content:center;">
                                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 7h10M7 7v10M7 7l10 10"/>
                                                                    </svg>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <svg aria-hidden="true" display="block" class="vkuiIcon vkuiIcon--24 vkuiIcon--w-24 vkuiIcon--h-24 vkuiIcon--document_list_outline_24"
                                                                        width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                                                    <path d="M7.996 13.901a.9.9 0 0 1 .9-.9h1.2a.9.9 0 0 1 0 1.8h-1.2a.9.9 0 0 1-.9-.9m.9 2.297a.9.9 0 1 0 0 1.8h1.2a.9.9 0 0 0 0-1.8z"></path>
