@model labsupport.ViewModels.TicketDetailsViewModel

@{
    ViewData["Title"] = $"Заявка #{Model.Ticket.TicketNumber}";
    var currentUserRoleId = User?.FindFirst("RoleId") != null ? int.Parse(User.FindFirst("RoleId")!.Value) : 0;
    bool isEngineerOrAdmin = currentUserRoleId == 1 || currentUserRoleId == 2;
}

<div class="app-container">
    @await Html.PartialAsync("_Sidebar")

    <main class="main-content ticket-details-page-v2">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">@TempData["Error"]</div>
        }

        <!-- Верхняя панель с заголовком и статусом -->
        <div class="ticket-header-v2">
            <div class="ticket-header-main">
                <div class="ticket-title-section">
                    <h1 class="ticket-title">@Model.Ticket.Title</h1>
                    <p class="ticket-meta">Заявка #@Model.Ticket.TicketNumber • Создана <span class="local-time" data-time="@Model.Ticket.CreatedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">@Model.Ticket.CreatedAt?.ToString("dd.MM.yyyy HH:mm")</span></p>
                </div>
                <div class="ticket-actions-v2">
                    <a href="@Url.Action("Index", "Ticket")" class="btn btn-back">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 12H5M12 19l-7-7 7-7"/>
                        </svg>
                        Назад к списку
                    </a>
                </div>
            </div>
            
            <div class="ticket-status-bar">
                <div class="status-badges-group">
                    <span class="status-badge-v2 @(Model.Ticket.Status.Name switch {
                        "Новая" => "status-new",
                        "В работе" => "status-in-progress",
                        "На проверке" => "status-review",
                        "Завершена" => "status-done",
                        "Отменена" => "status-cancelled",
                        _ => "status-default"
                    })">
                        @Model.Ticket.Status.Name
                    </span>
                    
                    <div class="priority-indicator">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="star @(i <= Model.Ticket.Priority ? "active" : "")">
                                @(i <= Model.Ticket.Priority ? "★" : "☆")
                            </span>
                        }
                    </div>
                </div>
                
                <div class="ticket-dates">
                    <div class="date-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                        </svg>
                        <span>Срок: <strong class="@(Model.Ticket.DueDate.HasValue && Model.Ticket.DueDate < DateTime.Now ? "overdue" : "")">@(Model.Ticket.DueDate?.ToString("dd.MM.yyyy HH:mm") ?? "Не установлен")</strong></span>
                    </div>
                    <div class="date-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/>
                        </svg>
                        <span>@(Model.Ticket.Category?.Name ?? "Без категории")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Основная сетка: слева описание и чат, справа информация -->
        <div class="ticket-grid-v2">
            <!-- Левая колонка: Описание + Чат -->
            <div class="main-column">
                <!-- Описание заявки -->
                <section class="card description-card">
                    <div class="card-header">
                        <h2 class="card-title">📝 Описание проблемы</h2>
                    </div>
                    <div class="card-body">
                        <div class="description-content">
                            @(Model.Ticket.Description ?? "Описание отсутствует")
                        </div>
                        
                        @if (Model.Ticket.TicketAttachments.Any())
                        {
                            <div class="attachments-section">
                                <h4 class="attachments-title">Вложения (@Model.Ticket.TicketAttachments.Count)</h4>
                                <div class="attachments-grid">
                                    @foreach (var attachment in Model.Ticket.TicketAttachments)
                                    {
                                        <a href="@attachment.FilePath" class="attachment-card" download>
                                            @await Html.PartialAsync("_FileIcons", attachment.FileName)
                                            <div class="attachment-info">
                                                <span class="attachment-name">@attachment.FileName</span>
                                                <span class="attachment-size">Скачать</span>
                                            </div>
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <!-- Чат -->
                <section class="card chat-card">
                    <div class="chat-header-v2">
                        <h2 class="card-title">💬 Обсуждение</h2>
                        <span class="messages-count">@Model.Comments.Count сообщений</span>
                    </div>
                    
                    <div class="chat-messages-v2" id="chat-messages">
                        @if (!Model.Comments.Any())
                        {
                            <div class="empty-chat">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                                </svg>
                                <p>Пока нет сообщений</p>
                                <span>Начните обсуждение первым</span>
                            </div>
                        }
                        else
                        {
                            @foreach (var comment in Model.Comments)
                            {
                                bool isOwnComment = comment.UserId == Model.CurrentUser.Id;
                                bool isInternal = comment.IsInternal ?? false;
                                
                                <div class="message-v2 @(isOwnComment ? "own" : "") @(isInternal ? "internal" : "")" data-comment-id="@comment.Id">
                                    <div class="message-wrapper">
                                        <div class="message-avatar-v2">
                                            @if (!string.IsNullOrEmpty(comment.User.AvatarPath))
                                            {
                                                <img src="@comment.User.AvatarPath" alt="Avatar" />
                                            }
                                            else
                                            {
                                                <div class="avatar-initials">
                                                    @((comment.User.FirstName?.FirstOrDefault().ToString() ?? "?") + (comment.User.LastName?.FirstOrDefault().ToString() ?? ""))
                                                </div>
                                            }
                                        </div>
                                        
                                        <div class="message-body">
                                            <div class="message-top">
                                                <span class="author-name">@comment.User.LastName @comment.User.FirstName</span>
                                                <span class="message-time local-time" data-time="@comment.CreatedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">@comment.CreatedAt?.ToString("HH:mm dd.MM")</span>
                                                @if (isInternal)
                                                {
                                                    <span class="internal-badge">🔒 Внутренний</span>
                                                }
                                            </div>
                                            
                                            <div class="message-text-v2">@comment.Content</div>
                                            
                                            @if (comment.MessageAttachments.Any())
                                            {
                                                <div class="message-files">
                                                    @foreach (var attachment in comment.MessageAttachments)
                                                    {
                                                        var fileName = attachment.FileName;
                                                        var extIndex = fileName.LastIndexOf('.');
                                                        var extension = extIndex > 0 ? fileName.Substring(extIndex + 1).ToUpper() : "FILE";
                                                        
                                                        var isImage = fileName.ToLower().EndsWith(".jpg") || 
                                                                      fileName.ToLower().EndsWith(".jpeg") || 
                                                                      fileName.ToLower().EndsWith(".png") || 
                                                                      fileName.ToLower().EndsWith(".gif") || 
                                                                      fileName.ToLower().EndsWith(".webp");
                                                      
                                                        <div class="file-chip" onclick="window.open('@Url.Content(attachment.FilePath)', '_blank')">
                                                            @if (isImage)
                                                            {
                                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/>
                                                                </svg>
                                                            }
                                                            else
                                                            {
                                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/>
                                                                </svg>
                                                            }
                                                            <span>@fileName</span>
                                                            <span class="file-ext">@extension</span>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            
                                            @if (comment.EditedAt.HasValue)
                                            {
                                                <div class="edited-note">
                                                    изменено <span class="local-time" data-time="@comment.EditedAt.Value.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">@comment.EditedAt.Value.ToString("dd.MM HH:mm")</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    
                    <!-- Форма отправки -->
                    <div class="chat-input-v2">
                        <form id="comment-form">
                            <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                            
                            @if (isEngineerOrAdmin)
                            {
                                <label class="internal-toggle">
                                    <input type="checkbox" name="isInternal" id="isInternal" />
                                    <span class="toggle-text">Внутренний комментарий (не видно пользователю)</span>
                                </label>
                            }
                            
                            <div class="input-group">
                                <textarea name="content" id="comment-content" placeholder="Напишите сообщение..." rows="2" class="chat-textarea"></textarea>
                                
                                <div class="input-actions-v2">
                                    <label for="comment-file-input" class="attach-btn" title="Прикрепить файлы">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/>
                                        </svg>
                                    </label>
                                    <input type="file" id="comment-file-input" multiple style="display: none;" accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx" />
                                    
                                    <button type="submit" class="send-btn">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                                        </svg>
                                        Отправить
                                    </button>
                                </div>
                            </div>
                            
                            <div id="comment-file-preview" class="file-preview-area"></div>
                        </form>
                    </div>
                </section>
            </div>

            <!-- Правая колонка: Информация -->
            <aside class="sidebar-column">
                <!-- Участники -->
                <section class="card participants-card">
                    <div class="card-header">
                        <h3 class="card-title-sm">👥 Участники</h3>
                    </div>
                    <div class="card-body">
                        <div class="participant-row">
                            <div class="participant-avatar">
                                @{ViewBag.AvatarSize = "small";}
                                <partial name="_UserAvatar" model="Model.Ticket.CreatedBy"/>
                            </div>
                            <div class="participant-info">
                                <span class="participant-role">Автор</span>
                                <strong>@Model.Ticket.CreatedBy.LastName @Model.Ticket.CreatedBy.FirstName</strong>
                                <span class="participant-dept">@Model.Ticket.CreatedBy.Department?.Name</span>
                            </div>
                        </div>
                        
                        <div class="participant-row">
                            <div class="participant-avatar">
                                @{ViewBag.AvatarSize = "small";}
                                <partial name="_UserAvatar" model="Model.Ticket.AssignedTo"/>
                            </div>
                            <div class="participant-info">
                                <span class="participant-role">Исполнитель</span>
                                <strong>@Model.Ticket.AssignedTo.LastName @Model.Ticket.AssignedTo.FirstName</strong>
                                <span class="participant-dept">@Model.Ticket.AssignedTo.Department?.Name</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Детали -->
                <section class="card details-card">
                    <div class="card-header">
                        <h3 class="card-title-sm">ℹ️ Детали</h3>
                    </div>
                    <div class="card-body">
                        <div class="detail-row">
                            <span class="detail-label">Номер</span>
                            <span class="detail-value">#@Model.Ticket.TicketNumber</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Категория</span>
                            <span class="detail-value">@(Model.Ticket.Category?.Name ?? "—")</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Создана</span>
                            <span class="detail-value local-time" data-time="@Model.Ticket.CreatedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">@Model.Ticket.CreatedAt?.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Обновлена</span>
                            <span class="detail-value">@Model.Ticket.UpdatedAt?.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Дедлайн</span>
                            <span class="detail-value @(Model.Ticket.DueDate.HasValue && Model.Ticket.DueDate < DateTime.Now ? "overdue" : "")">@(Model.Ticket.DueDate?.ToString("dd.MM.yyyy") ?? "—")</span>
                        </div>
                    </div>
                </section>

                <!-- История -->
                @if (Model.History.Any())
                {
                    <section class="card history-card">
                        <div class="card-header">
                            <h3 class="card-title-sm">📜 История</h3>
                        </div>
                        <div class="card-body">
                            <div class="history-list">
                                @foreach (var item in Model.History.OrderByDescending(h => h.ChangedAt).Take(10))
                                {
                                    <div class="history-entry">
                                        <div class="history-dot"></div>
                                        <div class="history-content-sm">
                                            <span class="history-user">@item.User.LastName @item.User.FirstName</span>
                                            <span class="history-action">изменил <strong>@item.FieldName</strong></span>
                                            @if (!string.IsNullOrEmpty(item.NewValue))
                                            {
                                                <span class="history-value">на "@item.NewValue"</span>
                                            }
                                            <span class="history-time-sm local-time" data-time="@item.ChangedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">@item.ChangedAt?.ToString("dd.MM HH:mm")</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>
                }

                <!-- Действия -->
                @if (isEngineerOrAdmin)
                {
                    <section class="card actions-card-v2">
                        <div class="card-header">
                            <h3 class="card-title-sm">⚙️ Управление</h3>
                        </div>
                        <div class="card-body">
                            <form asp-action="UpdateStatus" method="post" class="action-form-v2">
                                <label class="form-label">Статус</label>
                                <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                                <select name="statusId" onchange="this.form.submit()" class="form-select-v2">
                                    <option value="1" selected="@(Model.Ticket.StatusId == 1)">Новая</option>
                                    <option value="2" selected="@(Model.Ticket.StatusId == 2)">В работе</option>
                                    <option value="3" selected="@(Model.Ticket.StatusId == 3)">На проверке</option>
                                    <option value="4" selected="@(Model.Ticket.StatusId == 4)">Завершена</option>
                                    <option value="5" selected="@(Model.Ticket.StatusId == 5)">Отменена</option>
                                </select>
                            </form>

                            <form asp-action="UpdateAssignment" method="post" class="action-form-v2">
                                <label class="form-label">Исполнитель</label>
                                <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                                <select name="assignedToId" onchange="this.form.submit()" class="form-select-v2">
                                    @foreach (var assignee in Model.AvailableAssignees)
                                    {
                                        <option value="@assignee.Id" selected="@(assignee.Id == Model.Ticket.AssignedToId)">
                                            @assignee.LastName @assignee.FirstName
                                        </option>
                                    }
                                </select>
                            </form>
                        </div>
                    </section>
                }
            </aside>
        </div>
    </main>
</div>

<!-- Модальное окно для изображений -->
<div id="imageModal" class="image-modal" style="display: none;">
    <div class="image-modal-overlay"></div>
    <div class="image-modal-container">
        <button class="image-modal-close">×</button>
        <img id="modalImage" src="" alt="Preview">
        <div class="image-modal-caption">
            <span id="modalCaption"></span>
        </div>
    </div>
</div>

<!-- Контекстное меню -->
<div id="context-menu" class="context-menu-v2">
    <button id="ctx-edit-btn" class="ctx-menu-item">Редактировать</button>
    <button id="ctx-delete-btn" class="ctx-menu-item delete">Удалить</button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    ChatHelper.init(@Model.Ticket.Id, @Model.CurrentUser.Id);
    setTimeout(() => ChatHelper.scrollToBottom(), 100);

    let currentCommentId = null;
    let currentCommentContent = '';
    const ctxMenu = document.getElementById('context-menu');
    const ctxEditBtn = document.getElementById('ctx-edit-btn');
    const ctxDeleteBtn = document.getElementById('ctx-delete-btn');

    document.getElementById('chat-messages').addEventListener('contextmenu', function(e) {
        const messageEl = e.target.closest('.message-v2');
        if (!messageEl) return;

        const commentId = parseInt(messageEl.dataset.commentId);
        if (isNaN(commentId)) return;

        const isOwn = messageEl.classList.contains('own');
        if (!isOwn) return;

        e.preventDefault();
        const contentEl = messageEl.querySelector('.message-text-v2');
        currentCommentId = commentId;
        currentCommentContent = contentEl?.textContent || '';

        ctxMenu.style.display = 'block';
        ctxMenu.style.left = e.clientX + 'px';
        ctxMenu.style.top = e.clientY + 'px';

        ctxEditBtn.onclick = function() {
            ChatHelper.editMessage(currentCommentId, currentCommentContent);
            ctxMenu.style.display = 'none';
        };

        ctxDeleteBtn.onclick = function() {
            ChatHelper.deleteMessageRequest(currentCommentId);
            ctxMenu.style.display = 'none';
        };

        document.addEventListener('click', function hideMenu() {
            ctxMenu.style.display = 'none';
            document.removeEventListener('click', hideMenu);
        }, { once: true });
    });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && ctxMenu.style.display === 'block') {
            ctxMenu.style.display = 'none';
        }
    });

    const modal = document.getElementById('imageModal');
    if (modal) {
        modal.addEventListener('click', (e) => {
            if (e.target === modal || e.target.classList.contains('image-modal-overlay') || e.target.classList.contains('image-modal-close')) {
                window.FilePreviewHelper.closeImageModal();
            }
        });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modal.style.display === 'flex') {
                window.FilePreviewHelper.closeImageModal();
            }
        });
    }
});
</script>
