                                        </div>
                                    }
                                
                                    <div class="message-footer">
                                        <span class="message-time local-time" data-time="@comment.CreatedAt?.ToString("yyyy-MM-ddTHH:mm:ss.fffZ")">@comment.CreatedAt?.ToString("HH:mm")</span>
