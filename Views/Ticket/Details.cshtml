    async function loadDelegationCandidates() {
        const container = document.getElementById('candidates-list');
        if (!container) return;
        container.innerHTML = '<div class="loading-spinner">Загрузка...</div>';
        
        try {
          const ticketId = '@Model.Ticket.Id';
              console.log('ticketId:', ticketId);
            const response = await fetch(`/Ticket/GetDelegationCandidates?ticketId=${encodeURIComponent(ticketId)}`);
            if (!response.ok) throw new Error('Ошибка загрузки');
            delegationCandidates = await response.json();
            renderCandidatesList(delegationCandidates);
        } catch (error) {
            console.error(error);
            container.innerHTML = '<div class="loading-spinner">Не удалось загрузить список</div>';
        }
    }
    
    function renderCandidatesList(candidates) {
        const container = document.getElementById('candidates-list');
        if (!container) return;
        if (!candidates.length) {
            container.innerHTML = '<div class="loading-spinner">Нет доступных пользователей для делегирования</div>';
            return;
        }
        
        container.innerHTML = '';
        candidates.forEach(candidate => {
            const item = document.createElement('div');
            item.className = 'candidate-item';
            item.dataset.id = candidate.id;
            
            const avatarHtml = candidate.avatarPath 
                ? `<img src="${candidate.avatarPath}" alt="avatar">`
                : `<div class="initials">${(candidate.lastName?.[0] || '') + (candidate.firstName?.[0] || '')}</div>`;
            
            const onlineClass = candidate.isOnline ? 'online' : 'offline';
            
            item.innerHTML = `
                <div class="candidate-avatar">${avatarHtml}</div>
                <div class="candidate-info">
                    <div class="candidate-name">${escapeHtml(candidate.lastName)} ${escapeHtml(candidate.firstName)}</div>
                    <div class="candidate-role">
                        <span class="online-status ${onlineClass}"></span>
                        ${escapeHtml(candidate.role)}
                    </div>
                </div>
            `;
            item.addEventListener('click', () => selectCandidate(candidate.id));
            container.appendChild(item);
        });
    }
    
    function selectCandidate(userId) {
        selectedUserId = userId;
        document.querySelectorAll('.candidate-item').forEach(el => {
            if (parseInt(el.dataset.id) === userId) {
                el.classList.add('selected');
            } else {
                el.classList.remove('selected');
            }
        });
        
        const candidate = delegationCandidates.find(c => c.id === userId);
        if (candidate) {
            showUserDetails(candidate);
            const confirmBtn = document.getElementById('delegation-confirm-btn');
            if (confirmBtn) confirmBtn.disabled = false;
        } else {
            const confirmBtn = document.getElementById('delegation-confirm-btn');
            if (confirmBtn) confirmBtn.disabled = true;
        }
    }
    
    function showUserDetails(user) {
        const detailsPanel = document.getElementById('delegation-user-details');
        if (!detailsPanel) return;
        
        const avatarHtml = user.avatarPath 
            ? `<img src="${user.avatarPath}" alt="avatar">`
            : `<div class="initials">${escapeHtml((user.lastName?.[0] || '') + (user.firstName?.[0] || ''))}</div>`;
        
        const onlineStatus = user.isOnline 
            ? '<span class="online-status online"></span> В сети'
            : `<span class="online-status offline"></span> Был(а) ${escapeHtml(user.lastSeenText || 'неизвестно')}`;
        
        detailsPanel.innerHTML = `
            <div class="user-details-card">
                <div class="user-details-header">
                    <div class="user-details-avatar">
                        ${avatarHtml}
                    </div>
                    <div>
                        <div class="user-details-name">${escapeHtml(user.lastName)} ${escapeHtml(user.firstName)} ${escapeHtml(user.middleName || '')}</div>
                        <div class="user-details-role">${escapeHtml(user.role)}</div>
                    </div>
                </div>
                <div class="user-details-info">
                    <div class="info-row">
                        <div class="info-label">Email:</div>
                        <div class="info-value">${escapeHtml(user.email || '—')}</div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Отдел:</div>
                        <div class="info-value">${escapeHtml(user.department || '—')}</div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Должность:</div>
                        <div class="info-value">${escapeHtml(user.position || '—')}</div>
                    </div>
                    <div class="info-row">
