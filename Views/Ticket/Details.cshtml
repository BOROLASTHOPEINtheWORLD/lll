
@model labsupport.ViewModels.TicketDetailsViewModel

@{
    ViewData["Title"] = $"Заявка #{Model.Ticket.TicketNumber}";
    var currentUserRoleId = User?.FindFirst("RoleId") != null ? int.Parse(User.FindFirst("RoleId")!.Value) : 0;
    bool isEngineerOrAdmin = currentUserRoleId == 1 || currentUserRoleId == 2;
}


<div class="app-container">
    @await Html.PartialAsync("_Sidebar")

    <main class="main-content ticket-details-page">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">@TempData["Error"]</div>
        }

        <div class="ticket-details-layout">
            <!-- Левая часть - Информация о заявке -->
            <div class="ticket-info-panel">
                <div class="ticket-header">
                    <div class="ticket-header-top">
                        <div>
                            <h1>@Model.Ticket.Title</h1>
                            <p class="ticket-number">Заявка #@Model.Ticket.TicketNumber</p>
                        </div>
                        <div class="ticket-actions">
                            <a href="@Url.Action("Index", "Ticket")" class="btn btn-secondary">
                                ← Назад к списку
                            </a>
                        </div>
                    </div>

                    <div class="ticket-badges">
                        <span class="status-badge @(Model.Ticket.Status.Name switch {
                            "Новая" => "status-open",
                            "В работе" => "status-progress",
                            "На проверке" => "status-progress",
                            "Завершена" => "status-resolved",
                            "Отменена" => "status-default",
                            _ => "status-default"
                        })">
                            @Model.Ticket.Status.Name
                        </span>

                        <div class="priority-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span style="color: @(i <= Model.Ticket.Priority ? "#F59E0B" : "#D1D5DB");">
                                    @(i <= Model.Ticket.Priority ? "★" : "☆")
                                </span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Основная информация -->
                <div class="info-card">
                    <h3>📋 Основная информация</h3>
                    <div class="info-grid">
                        <div class="info-item">
                            <label>Категория:</label>
                            <span>@(Model.Ticket.Category?.Name ?? "Не указана")</span>
                        </div>
                        <div class="info-item">
                            <label>Создана:</label>
                            <span>@Model.Ticket.CreatedAt?.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="info-item">
                            <label>Обновлена:</label>
                            <span>@Model.Ticket.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-"</span>
                        </div>
                        <div class="info-item">
                            <label>Срок исполнения:</label>
                            <span class="@(Model.Ticket.DueDate.HasValue && Model.Ticket.DueDate < DateTime.Now ? "overdue" : "")">
                                @(Model.Ticket.DueDate?.ToString("dd.MM.yyyy HH:mm") ?? "Не установлен")
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Описание -->
                <div class="info-card">
                    <h3>📝 Описание</h3>
                    <div class="ticket-description">
                        @(Model.Ticket.Description ?? "Описание отсутствует")
                    </div>
                </div>

                <!-- Автор и исполнитель -->
                <div class="info-grid-2">
                    <div class="info-card">
                        <h3>👤 Автор заявки</h3>
                        <div class="user-info">
                            @{
                                ViewBag.AvatarSize = "small";
                            }
                            <partial name="_UserAvatar" model="Model.Ticket.CreatedBy"/>
      
                            <div>
                                <strong>@Model.Ticket.CreatedBy.LastName @Model.Ticket.CreatedBy.FirstName</strong>
                                <p>@Model.Ticket.CreatedBy.Department?.Name</p>
                                <p>@Model.Ticket.CreatedBy.Position?.Name</p>
                            </div>
                        </div>
                    </div>

                    <div class="info-card">
                        <h3>🔧 Исполнитель</h3>
                        <div class="user-info">
                                 @{
                                ViewBag.AvatarSize = "small";
                            }
                            <partial name="_UserAvatar" model="Model.Ticket.AssignedTo"/>
                            <div>
                                <strong>@Model.Ticket.AssignedTo.LastName @Model.Ticket.AssignedTo.FirstName</strong>
                                <p>@Model.Ticket.AssignedTo.Department?.Name</p>
                                <p>@Model.Ticket.AssignedTo.Position?.Name</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Вложения заявки -->
                @if (Model.Ticket.TicketAttachments.Any())
                {
                    <div class="info-card">
                        <h3>📎 Вложения (@Model.Ticket.TicketAttachments.Count)</h3>
                        <div class="attachments-list">
                            @foreach (var attachment in Model.Ticket.TicketAttachments)
                            {
                                <a href="@attachment.FilePath" class="attachment-item" download>
                                    @await Html.PartialAsync("_FileIcons", attachment.FileName)
                                    <span>@attachment.FileName</span>
                                </a>
                            }
                        </div>
                    </div>
                }

                <!-- История изменений -->
                @if (Model.History.Any())
                {
                    <div class="info-card">
                        <h3>📜 История изменений</h3>
                        <div class="history-timeline">
                            @foreach (var item in Model.History.OrderByDescending(h => h.ChangedAt).Take(20))
                            {
                                <div class="history-item">
                                    <div class="history-time">@item.ChangedAt?.ToString("dd.MM.yyyy HH:mm")</div>
                                    <div class="history-content">
                                        <strong>@item.User.LastName @item.User.FirstName</strong>
                                        <span>изменил "@item.FieldName"</span>
                                        @if (!string.IsNullOrEmpty(item.NewValue))
                                        {
                                            <span>на "@item.NewValue"</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Панель действий для инженеров/админов -->
                @if (isEngineerOrAdmin)
                {
                    <div class="info-card actions-card">
                        <h3>⚙️ Действия</h3>

                        <form asp-action="UpdateStatus" method="post" class="action-form">
                            <label>Изменить статус:</label>
                            <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                            <select name="statusId" onchange="this.form.submit()" class="form-control">
                                <option value="1" selected="@(Model.Ticket.StatusId == 1)">Новая</option>
                                <option value="2" selected="@(Model.Ticket.StatusId == 2)">В работе</option>
                                <option value="3" selected="@(Model.Ticket.StatusId == 3)">На проверке</option>
                                <option value="4" selected="@(Model.Ticket.StatusId == 4)">Завершена</option>
                                <option value="5" selected="@(Model.Ticket.StatusId == 5)">Отменена</option>
                            </select>
                        </form>

                        <form asp-action="UpdateAssignment" method="post" class="action-form">
                            <label>Назначить исполнителя:</label>
                            <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />
                            <select name="assignedToId" onchange="this.form.submit()" class="form-control">
                                @foreach (var assignee in Model.AvailableAssignees)
                                {
                                    <option value="@assignee.Id" selected="@(assignee.Id == Model.Ticket.AssignedToId)">
                                        @assignee.LastName @assignee.FirstName
                                    </option>
                                }
                            </select>
                        </form>
                    </div>
                }
            </div>

            <!-- Правая часть - Чат -->
            <div class="chat-panel">
                <div class="chat-header">
                    <h3>Чат</h3>
                </div>

                <div class="chat-messages" id="chat-messages">
                    @if (!Model.Comments.Any())
                    {
                        <div class="no-messages">
                            <p>Сообщений пока нет</p>
                            <span>Будьте первым, кто напишет комментарий</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments)
                        {
                            bool isOwnComment = comment.UserId == Model.CurrentUser.Id;
                            bool isInternal = comment.IsInternal ?? false;

                            <div class="message @(isOwnComment ? "message-own" : "") @(isInternal ? "message-internal" : "")">
                                <div class="message-avatar">
                                    @if (!string.IsNullOrEmpty(comment.User.AvatarPath))
                                    {
                                        <img src="@comment.User.AvatarPath" alt="Avatar" />
                                    }
                                    else
                                    {
                                        <div class="avatar-placeholder">
                                            @((comment.User.FirstName?.FirstOrDefault().ToString() ?? "?") + (comment.User.LastName?.FirstOrDefault().ToString() ?? ""))
                                        </div>
                                    }
                                </div>
                                <div class="message-content">
                                    <div class="message-header">
                                        <span class="message-author">@comment.User.LastName @comment.User.FirstName</span>
                                        <span class="message-time">@comment.CreatedAt?.ToString("dd.MM.yyyy HH:mm")</span>
                                        @if (isInternal)
                                        {
                                            <span class="badge-internal">Внутренний</span>
                                        }
                                    </div>
                                    <div class="message-text">@comment.Content</div>

                                    @if (comment.MessageAttachments.Any())
                                    {
                                        <div class="message-attachments">
                                        @foreach (var attachment in comment.MessageAttachments)
                                        {
                                            // Извлекаем расширение вручную (без Path)
                                            var fileName = attachment.FileName;
                                            var extIndex = fileName.LastIndexOf('.');
                                            var extension = extIndex > 0 ? fileName.Substring(extIndex + 1).ToUpper() : "BIN";

                                            var isImage = fileName.ToLower().EndsWith(".jpg") || 
                                                            fileName.ToLower().EndsWith(".jpeg") || 
                                                            fileName.ToLower().EndsWith(".png") || 
                                                            fileName.ToLower().EndsWith(".gif") || 
                                                            fileName.ToLower().EndsWith(".webp");

                                            <div class="AttachmentCell AttachmentCell--clickable"
                                                    onclick="window.open('@Url.Content(attachment.FilePath)', '_blank')">
                                                <div class="AttachmentCell__imageBlockContainer">
                                                    <div class="AttachmentCell__imageBlockBackground"></div>
                                                    <div class="AttachmentCell__imageBlock">
                                                        @if (isImage)
                                                        {
                                                            <div style="width:100%;height:100%;background:#f5f7fa;display:flex;align-items:center;justify-content:center;">
                                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 7h10M7 7v10M7 7l10 10"/>
                                                                </svg>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <!-- Универсальная иконка документа (точная копия из VK) -->
                                                            <svg aria-hidden="true" display="block" class="vkuiIcon vkuiIcon--24 vkuiIcon--w-24 vkuiIcon--h-24 vkuiIcon--document_list_outline_24"
                                                                    width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                                                <path d="M7.996 13.901a.9.9 0 0 1 .9-.9h1.2a.9.9 0 0 1 0 1.8h-1.2a.9.9 0 0 1-.9-.9m.9 2.297a.9.9 0 1 0 0 1.8h1.2a.9.9 0 0 0 0-1.8zM13 13.901a.9.9 0 0 1 .9-.9h1.2a.9.9 0 0 1 0 1.8h-1.2a.9.9 0 0 1-.9-.9m.9 2.297a.9.9 0 1 0 0 1.8h1.2a.9.9 0 0 0 0-1.8z"></path>
                                                                <path fill-rule="evenodd" d="M12.473 2c.3 0 .586 0 .866.066a2.4 2.4 0 0 1 .694.288c.245.15.447.353.659.565l4.389 4.39c.212.21.415.413.565.658a2.4 2.4 0 0 1 .288.694c.067.28.066.566.066.866v6.012c0 .947 0 1.713-.05 2.333-.053.64-.163 1.203-.43 1.726a4.4 4.4 0 0 1-1.922 1.922c-.523.267-1.087.377-1.726.43-.62.05-1.386.05-2.334.05h-3.076c-.948 0-1.714 0-2.334-.05-.64-.053-1.203-.163-1.726-.43a4.4 4.4 0 0 1-1.922-1.922c-.267-.523-.377-1.087-.43-1.726C4 17.252 4 16.486 4 15.538V8.462c0-.948 0-1.714.05-2.334.053-.64.163-1.203.43-1.726A4.4 4.4 0 0 1 6.402 2.48c.523-.267 1.087-.377 1.726-.43C8.748 2 9.514 2 10.462 2zM10.5 3.8H12v2.135c0 .53 0 .981.03 1.352.032.39.102.768.286 1.13a2.9 2.9 0 0 0 1.267 1.267c.362.184.741.254 1.13.286.37.03.822.03 1.351.03H18.2v5.5c0 .995 0 1.687-.045 2.226-.043.527-.123.828-.238 1.054a2.6 2.6 0 0 1-1.137 1.137c-.226.115-.527.195-1.055.238-.538.044-1.23.045-2.225.045h-3c-.995 0-1.687 0-2.226-.045-.527-.043-.828-.123-1.054-.238a2.6 2.6 0 0 1-1.137-1.137c-.115-.226-.195-.527-.238-1.055-.044-.538-.045-1.23-.045-2.225v-7c0-.995 0-1.687.045-2.225.043-.528.123-.829.238-1.055A2.6 2.6 0 0 1 7.22 4.083c.226-.115.527-.195 1.054-.238C8.813 3.8 9.505 3.8 10.5 3.8m3.3.773L17.427 8.2H16.1c-.575 0-.952 0-1.24-.024-.278-.023-.393-.062-.46-.096a1.1 1.1 0 0 1-.48-.48c-.034-.066-.073-.182-.096-.46A17 17 0 0 1 13.8 5.9z" clip-rule="evenodd"></path>
                                                            </svg>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="AttachmentCell__infoBlockContainer">
                                                    <div class="AttachmentCell__infoBlock">
                                                        <h4 class="AttachmentCell__headline">@fileName</h4>
                                                        <span class="AttachmentCell__footnote">
                                                            @extension
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        </div>
                                    }

                                    @if (comment.EditedAt.HasValue)
                                    {
                                        <div class="message-edited">
                                            Отредактировано @comment.EditedAt.Value.ToString("dd.MM.yyyy HH:mm")
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Форма отправки комментария -->
                <div class="chat-input-area">
                    <form id="comment-form">
                        <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />

                        <div class="comment-options">
                            @if (isEngineerOrAdmin)
                            {
                                <label class="checkbox-label">
                                    <input type="checkbox" name="isInternal" id="isInternal" />
                                    <span>Внутренний комментарий (не видно пользователю)</span>
                                </label>
                            }
                        </div>

                        <div class="input-wrapper">
                            <textarea
                                name="content"
                                id="comment-content"
                                placeholder="Введите комментарий..."
                                rows="3"
                                class="comment-textarea"></textarea>

                            <div class="input-actions">
                                <button type="button" class="btn-attach" id="comment-attach-btn" title="Прикрепить файл">
                                    <svg viewBox="0 0 24 24" width="20" height="20">
                                        <path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5a2.5 2.5 0 0 1 5 0v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5a2.5 2.5 0 0 0 5 0V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/>
                                    </svg>
                                </button>
                                <input type="file" id="comment-file-input" multiple style="display: none;" accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx" />
                                <button type="submit" class="btn-send">
                                    <svg viewBox="0 0 24 24" width="20" height="20">
                                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                                    </svg>
                                    Отправить
                                </button>
                            </div>
                        </div>

                        <!-- Превью выбранных файлов -->
                        <div id="comment-file-preview" class="file-preview-container"></div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>


<!-- Модальное окно для просмотра изображений -->
<div id="imageModal" class="image-modal" style="display: none;">
    <div class="image-modal-overlay"></div>
    <div class="image-modal-container">
        <button class="image-modal-close">&times;</button>
        <img id="modalImage" src="" alt="Preview">
        <div class="image-modal-caption">
            <span id="modalCaption"></span>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/file-preview.js"></script>
    <script src="~/js/chat.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ticketId = @Model.Ticket.Id;
            const currentUserId = @Model.CurrentUser.Id;

            // Инициализация чата через SignalR
            if (window.ChatHelper) {
                ChatHelper.init(ticketId, currentUserId);
            }

            // Заполняем select статусов из БД
            loadStatusesFromDb();
        });

        // Загрузка статусов из БД
        async function loadStatusesFromDb() {
            try {
                const response = await fetch('/Ticket/GetStatuses');
                if (response.ok) {
                    const statuses = await response.json();
                    const statusSelect = document.querySelector('select[name="statusId"]');

                    if (statusSelect) {
                        const currentValue = statusSelect.value;
                        statusSelect.innerHTML = '';

                        statuses.forEach(status => {
                            const option = document.createElement('option');
                            option.value = status.id;
                            option.textContent = status.name;
                            option.selected = status.id == currentValue;
                            statusSelect.appendChild(option);
                        });
                    }
                }
            } catch (error) {
                console.error('Error loading statuses:', error);
            }
        }
    </script>
}
