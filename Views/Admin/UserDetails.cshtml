@{
    ViewData["Title"] = ViewBag.IsNewUser == true ? "Создание пользователя" : (ViewBag.EditMode == true ? "Редактирование пользователя" : "Просмотр пользователя");
    var user = ViewBag.User as labsupport.Models.User;
    var editMode = ViewBag.EditMode == true || ViewBag.IsNewUser == true;
    var isNewUser = ViewBag.IsNewUser == true;
    var roles = ViewBag.Roles as List<labsupport.Models.Role>;
    var departments = ViewBag.Departments as List<labsupport.Models.Department>;
    var positions = ViewBag.Positions as List<labsupport.Models.Position>;
}

<div class="app-container">
    @await Html.PartialAsync("_Sidebar")

    <main class="main-content create-ticket-page">
        <div class="page-header">
            <h1>@(isNewUser ? "Создание пользователя" : (editMode ? "Редактирование пользователя" : ""))</h1>
        </div>

        @if (TempData["Success"] != null)   
        {
            <div class="alert-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert-error">
                @TempData["Error"]
            </div>
        }

        <div class="form-card">
            <div class="form-header">
                <div class="form-header-icon">
                    <svg viewBox="0 0 24 24" width="28" height="28">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                </div>
                <div class="form-header-content">
                    <h2>@(isNewUser ? "Новый пользователь" : (user?.LastName + " " + user?.FirstName))</h2>
                </div>
            </div>

            <div class="form-body">
                @if (editMode)
                {
                    <!-- РЕЖИМ РЕДАКТИРОВАНИЯ -->
                    <form method="post" asp-action="UserDetails" asp-route-id="@(user?.Id ?? 0)" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <partial name="_UserFormFields" model="user" />

                        <div class="form-actions">
                            <a href="@Url.Action("UserDetails", new { id = user?.Id, editMode = false })" class="btn btn-secondary">Отмена</a>
                            <button type="submit" class="btn btn-primary">
                                <svg viewBox="0 0 24 24" width="18" height="18">
                                    <path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" />
                                </svg>
                                Сохранить
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <!-- РЕЖИМ ПРОСМОТРА -->
                    <partial name="_UserViewFields" model="user" />

                    <div class="form-actions">
                        @if (!isNewUser && user != null)
                        {
                            <a href="@Url.Action("UserDetails", new { id = user.Id, editMode = true })" class="btn btn-primary">
                                <svg viewBox="0 0 24 24" width="18" height="18">
                                    <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                </svg>
                                Редактировать
                            </a>
                        }
                        <a href="@Url.Action("Users")" class="btn btn-secondary">Назад к списку</a>
                    </div>
                }
            </div>
        </div>
    </main>
</div>